# =============================================================================
# QORA — Environment Variables
# =============================================================================
# Local dev:  Copy this file to backend/.env and fill in the values.
# Docker:     Copy this file to .env (repo root) and fill in the values.
#             docker-compose.yml reads env_file: .env from the repo root.
#
# Required variables MUST be set for the application to start.
# =============================================================================

# ---------------------------------------------------------------------------
# OpenAI (REQUIRED)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# Optional model overrides
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini

# ---------------------------------------------------------------------------
# ElevenLabs (REQUIRED)
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=4wDRKlxcHNOFO5kBvE81  # Melisa (Sofia — Qora demo default)

# Voice tuning (OPTIONAL)
# ELEVENLABS_STABILITY=0.4
# ELEVENLABS_SPEED=0.95

# ElevenLabs Conversational AI — Qora Demo agent
ELEVENLABS_AGENT_ID=agent_8201kra4wjhve0srcwgbtwfetr5n
CUSTOM_LLM_WEBHOOK_URL=https://YOUR_NGROK_URL/api/v1/voice/custom-llm

# ---------------------------------------------------------------------------
# Database (OPTIONAL — SQLite default)
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite+aiosqlite:///./qora.db

# ---------------------------------------------------------------------------
# App (OPTIONAL)
# ---------------------------------------------------------------------------
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
# DEBUG=false

# ---------------------------------------------------------------------------
# QORA defaults (OPTIONAL)
# ---------------------------------------------------------------------------
# FILLER_TIMEOUT_MS=500
# DEFAULT_BROKER_NAME=Quintana Seguros
# DEFAULT_AGENT_NAME=Jaumpablo
# Note: DEFAULT_CLIENT_ID has been removed. client_id is now required in all requests.

# ---------------------------------------------------------------------------
# Authentication (Phase B5 — required)
# ---------------------------------------------------------------------------
# Set QORA_API_KEY to a strong random secret before first deployment.
# All admin API routes require: Authorization: Bearer <QORA_API_KEY>
# Health check (/api/v1/health), /docs, /redoc, and /demo are exempt.
# Phase C: replaced by Supabase JWT — zero router changes needed.
#
# Generate a key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
QORA_API_KEY=change-me-before-production

# OpenAPI docs toggle. Default: enabled (True). Set False in production.
# QORA_DOCS_ENABLED=true

# Demo client/agent identity (Phase B5 — PR #2, used here for reference)
# QORA_DEMO_CLIENT_ID=your-demo-client-id
# QORA_DEMO_AGENT_ID=your-demo-agent-id

# Session TTL in seconds (default: 4 hours = 14400)
# QORA_SESSION_TTL_SECONDS=14400

# Webhook auth (Phase B5 — PR #3, disabled by default)
# QORA_WEBHOOK_AUTH_ENABLED=false
# QORA_WEBHOOK_SECRET=

# CORS (Phase B5 — PR #3, open by default for dev)
# QORA_ALLOWED_ORIGINS=https://your-frontend.com,https://admin.your-domain.com

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
# n8n is no longer wired into the analysis runtime. The exported workflow at
# docs/n8n-workflows/post-call-analysis.json and docker-compose.n8n-local.yml
# are kept only for diagramming and reference — there are no environment
# variables to set.

# ---------------------------------------------------------------------------
# Docker (set by docker-compose.yml — do NOT set here for Docker deployments)
# ---------------------------------------------------------------------------
# When running via `docker compose up`, these values are injected by
# docker-compose.yml and override anything set in .env.
#
# DATABASE_URL=sqlite+aiosqlite:////app/data/qora.db
#   SQLite on the named Docker volume (qora-data → /app/data/).
#   Do NOT change this for Docker deployments; the path must match the
#   volume mount defined in docker-compose.yml.
#
# QORA_SKIP_BACKUP_CHECK=1
#   Disables the pre-migration backup guard in scripts/migrate.py.
#   Safe in Docker because the named volume already persists the DB between
#   restarts. Only set this to 0 (or unset) if you add a separate backup step.
