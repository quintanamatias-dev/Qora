# =============================================================================
# QORA — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables MUST be set for the application to start.
# =============================================================================

# ---------------------------------------------------------------------------
# OpenAI (REQUIRED)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# Optional model overrides
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini

# ---------------------------------------------------------------------------
# ElevenLabs (REQUIRED)
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=4wDRKlxcHNOFO5kBvE81  # Melisa (Sofia — Qora demo default)

# Voice tuning (OPTIONAL)
# ELEVENLABS_STABILITY=0.4
# ELEVENLABS_SPEED=0.95

# ElevenLabs Conversational AI — Qora Demo agent
ELEVENLABS_AGENT_ID=agent_8201kra4wjhve0srcwgbtwfetr5n
CUSTOM_LLM_WEBHOOK_URL=https://YOUR_NGROK_URL/api/v1/voice/custom-llm

# ---------------------------------------------------------------------------
# Database (OPTIONAL — SQLite default)
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite+aiosqlite:///./qora.db

# ---------------------------------------------------------------------------
# App (OPTIONAL)
# ---------------------------------------------------------------------------
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
# DEBUG=false

# ---------------------------------------------------------------------------
# QORA defaults (OPTIONAL)
# ---------------------------------------------------------------------------
# FILLER_TIMEOUT_MS=500
# DEFAULT_BROKER_NAME=Quintana Seguros
# DEFAULT_AGENT_NAME=Jaumpablo
# Note: DEFAULT_CLIENT_ID has been removed. client_id is now required in all requests.

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
# n8n is no longer wired into the analysis runtime. The exported workflow at
# docs/n8n-workflows/post-call-analysis.json and docker-compose.n8n-local.yml
# are kept only for diagramming and reference — there are no environment
# variables to set.
