# =============================================================================
# QORA — Environment Variables (B8: root .env is the single source of truth)
# =============================================================================
#
# Setup (local dev):
#   Copy this file to .env at the repo root and fill in the values.
#   The application reads from repo-root/.env. Do NOT create backend/.env.
#
# Setup (Docker):
#   docker-compose.yml reads env_file: .env from the repo root automatically.
#   Same file — nothing extra to do.
#
# Pre-flight check before deploying:
#   python backend/scripts/check-secrets.py
#   Exit 0 = all required secrets are set. Exit 1 = deploy blocked.
#
# Generate a strong random key:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Operator runbook (rotation, audit, CI/CD, classification detail):
#   docs/ops/secrets-management.md
#
# Sections:
#   REQUIRED    — app refuses to start if missing or placeholder
#   CONDITIONAL — required only when a specific feature is enabled
#   PER_CLIENT  — required if that client's integration is active
#   OPTIONAL    — has a working default; override only if needed
#   FUTURE      — not wired in current code; reserved for upcoming phases
# =============================================================================


# ---------------------------------------------------------------------------
# REQUIRED — CRITICAL
# Startup fails with a clear error if these are missing or a weak placeholder.
# ---------------------------------------------------------------------------

OPENAI_API_KEY=sk-proj-...
ELEVENLABS_API_KEY=sk_...


# ---------------------------------------------------------------------------
# REQUIRED — HIGH
# Required in all environments (dev, staging, production).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ---------------------------------------------------------------------------

QORA_API_KEY=change-me-before-production


# ---------------------------------------------------------------------------
# CONDITIONAL — HIGH
# Required only when QORA_WEBHOOK_AUTH_ENABLED=true.
# Startup fails if auth is enabled but the secret is absent or empty.
# ---------------------------------------------------------------------------

# QORA_WEBHOOK_AUTH_ENABLED=false
# QORA_WEBHOOK_SECRET=


# ---------------------------------------------------------------------------
# PER_CLIENT — HIGH (required if that client's CRM integration is active)
# Startup fails at the CRM credential scan step if referenced but missing.
# ---------------------------------------------------------------------------

# Quintana Seguros — Airtable integration
QUINTANA_AIRTABLE_API_KEY=pat...


# ---------------------------------------------------------------------------
# OPTIONAL — ElevenLabs (voice tuning)
# Working defaults shown. Override only if your deployment differs.
# ---------------------------------------------------------------------------

ELEVENLABS_VOICE_ID=4wDRKlxcHNOFO5kBvE81
ELEVENLABS_AGENT_ID=agent_8201kra4wjhve0srcwgbtwfetr5n

# ELEVENLABS_MODEL=eleven_flash_v2_5
# ELEVENLABS_STABILITY=0.4
# ELEVENLABS_SPEED=0.95
# ELEVENLABS_SIMILARITY_BOOST=0.75


# ---------------------------------------------------------------------------
# OPTIONAL — Database
# Defaults to local SQLite. Docker overrides this via docker-compose.yml.
# Do NOT set DATABASE_URL here for Docker deployments.
# ---------------------------------------------------------------------------

# DATABASE_URL=sqlite+aiosqlite:///./qora.db


# ---------------------------------------------------------------------------
# OPTIONAL — App server
# ---------------------------------------------------------------------------

# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
# DEBUG=false


# ---------------------------------------------------------------------------
# OPTIONAL — QORA feature flags and defaults
# ---------------------------------------------------------------------------

# Outbound Call Trigger (Phase C2)
# Default: false — no calls placed, no charges incurred until explicitly enabled.
# Set ELEVENLABS_PHONE_NUMBER_ID first (see ElevenLabs SIP trunk operator checklist §2.2).
# Rollback: set to false or remove — immediate effect; no code change needed.
# ENABLE_OUTBOUND_CALLS=false
# ELEVENLABS_PHONE_NUMBER_ID=pnum_...

# Toggle OpenAPI docs (/docs + /redoc). Default: enabled. Set false in production.
# QORA_DOCS_ENABLED=true

# CORS origins. Default: * (open). Restrict in production.
# QORA_ALLOWED_ORIGINS=https://your-frontend.com,https://admin.your-domain.com

# Demo identity (Phase B5 PR #2)
# QORA_DEMO_CLIENT_ID=your-demo-client-id
# QORA_DEMO_AGENT_ID=your-demo-agent-id

# Session TTL in seconds (default: 4 hours)
# QORA_SESSION_TTL_SECONDS=14400

# FILLER_TIMEOUT_MS=500


# ---------------------------------------------------------------------------
# OPTIONAL — Model overrides
# ---------------------------------------------------------------------------

# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini


# ---------------------------------------------------------------------------
# FUTURE — Not yet wired into app code
# These variables are reserved for upcoming phases. Safe to leave unset.
# n8n: post-call analysis automation (not active — reference only)
# ---------------------------------------------------------------------------

# N8N_ENABLED=true
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/qora-post-call-analysis
# N8N_WEBHOOK_SECRET=
# N8N_INTERNAL_API_KEY=
# N8N_TIMEOUT_SECONDS=5

# Twilio: outbound calling (Phase C — not active)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Legacy: broker display name (replaced by per-client config in crm.yaml)
# BROKER_NAME=


# ---------------------------------------------------------------------------
# Docker runtime (injected by docker-compose.yml — do NOT set manually)
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite+aiosqlite:////app/data/qora.db
# QORA_SKIP_BACKUP_CHECK=1
