# =============================================================================
# QORA Frontend — Environment Variables
# =============================================================================
# Copy to frontend/.env and fill in values.
# Vite bakes VITE_* vars into the JavaScript bundle at build time.
# =============================================================================

# Backend API base URL.
# Leave empty for same-origin access (proxied via Vite dev server).
# In Docker or production, set to the backend's public URL.
VITE_API_BASE_URL=

# ⚠️  BROWSER-VISIBLE SECRET — read before setting this value.
#
# VITE_API_KEY must match QORA_API_KEY in the backend .env.
# This value is baked into the JS bundle at build time by Vite.
# Anyone with DevTools open can read it from the bundle or network requests.
#
# Acceptable NOW: single-operator, internal-only dashboard, no external users.
# Phase C replacement: JWT login flow — VITE_API_KEY is removed and each
# operator logs in with their credentials; no static key in the bundle.
#
# Rotation: change the value here AND in the backend .env, then rebuild.
# Never use a production QORA_API_KEY as VITE_API_KEY if external users have
# access to the frontend bundle.
VITE_API_KEY=
